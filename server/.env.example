# Flip Lens backend — copy to .env and adjust.

# HTTP
PORT=8787
# Comma-separated list of allowed CORS origins. The Chrome extension's origin is
# chrome-extension://<EXTENSION_ID>. Use * only for local dev.
CORS_ORIGINS=*

# Postgres
DATABASE_URL=postgres://flip:flip@localhost:5432/flip_lens

# Default tenant/user used until auth is built. These UUIDs are seeded by the
# initial migration. The requireTenant middleware injects them on every request.
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001

# Object storage for thumbnails.
#   local -> writes to STORAGE_LOCAL_DIR and serves via GET /images/:key (dev)
#   s3    -> any S3-compatible bucket (AWS S3, Cloudflare R2, MinIO, ...)
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./.data/images
# Public base URL used to build thumbnail URLs for the local driver.
# Defaults to http://localhost:${PORT}/images
PUBLIC_BASE_URL=

# --- S3 / Cloudflare R2 (only needed when STORAGE_DRIVER=s3) ---
# For Cloudflare R2: S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public, CDN-fronted base URL for objects (e.g. https://cdn.example.com or the
# R2 public bucket URL). Thumbnail URLs are built as ${S3_PUBLIC_BASE_URL}/${key}
S3_PUBLIC_BASE_URL=
