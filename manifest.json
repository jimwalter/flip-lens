{
  "manifest_version": 3,
  "name": "Flip Lens",
  "version": "0.1.0",
  "description": "Drag-select an item on any page, reverse-image-search it on Google Lens, and log it to a sortable resale-value history.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "clipboardWrite",
    "sidePanel",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://lens.google.com/*",
    "https://www.google.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Flip Lens — drag to crop an item",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel/panel.html"
  },
  "commands": {
    "trigger-crop": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Flip Lens: drag to crop an item"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "fliplens_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
